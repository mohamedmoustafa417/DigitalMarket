rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isSeller() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isNotBanned() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('disabled', false) == false;
    }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    // Buyer must have at least one approved order containing this productId.
    function hasPurchased(productId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/orders/$(request.auth.uid + '_' + productId));
    }

    // ── Products ─────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if resource.data.status == 'approved'
                  || isAdmin()
                  || (isSignedIn() && request.auth.uid == resource.data.sellerId);

      allow create: if isSeller() && isNotBanned()
                    && request.resource.data.sellerId == request.auth.uid
                    && request.resource.data.status in ['pending', 'draft'];

      // SECURITY: seller can edit own product, but CANNOT self-approve or self-feature.
      // status writes restricted: seller can only set 'pending' or 'draft' (resubmit),
      // never 'approved' / 'rejected' / 'featured'. Admin can do anything.
      allow update: if isAdmin()
                    || (
                      isSeller() && isNotBanned()
                      && request.auth.uid == resource.data.sellerId
                      && !changedKeys().hasAny(['verified', 'featured', 'sellerId', 'createdAt'])
                      && (
                        !changedKeys().hasAny(['status'])
                        || request.resource.data.status in ['pending', 'draft']
                      )
                    );

      allow delete: if isAdmin()
                    || (isSeller() && request.auth.uid == resource.data.sellerId);
    }

    // ── Orders ───────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.buyerId ||
        resource.data.sellerIds.hasAny([request.auth.uid]) ||
        isAdmin()
      );

      // status MUST be 'pending' (InstaPay/manual flow) or 'awaiting_payment'
      // (Kashier card flow). It can NEVER be 'approved' on create — only the
      // admin or the signed Kashier webhook (admin SDK, bypasses rules) may
      // flip an order to 'approved', which is what unlocks download tokens.
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.status in ['pending', 'awaiting_payment'];

      // SECURITY: seller can ONLY add a sellerNote / mark fulfilled.
      // status='approved' is admin-only — sellers cannot self-approve an order
      // to unlock download tokens and license keys.
      // The BUYER may ONLY flag their own order as refund-requested (true) —
      // nothing else (status, total, tokens stay locked to admin/CF).
      allow update: if isAdmin()
                    || (
                      isSeller() && resource.data.sellerIds.hasAny([request.auth.uid])
                      && changedKeys().hasOnly(['sellerNote', 'updatedAt'])
                    )
                    || (
                      request.auth.uid == resource.data.buyerId
                      && changedKeys().hasOnly(['refundRequested', 'updatedAt'])
                      && request.resource.data.refundRequested == true
                      // Refund policy: digital goods are non-refundable once
                      // downloaded — block the request after the order is consumed.
                      && resource.data.downloaded != true
                    );

      allow delete: if isAdmin();
    }

    // ── Reviews ──────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      // SECURITY: rating must be 1–5 integer, productId/buyerId set,
      // and the buyer must have an approved order for this product.
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.productId is string
                    && hasPurchased(request.resource.data.productId);
      // Buyer may edit their own review (rating stays in bounds, productId immutable).
      allow update: if isAdmin()
                    || (
                      isSignedIn() && request.auth.uid == resource.data.buyerId
                      && request.resource.data.rating is int
                      && request.resource.data.rating >= 1
                      && request.resource.data.rating <= 5
                      && request.resource.data.productId == resource.data.productId
                      && request.resource.data.buyerId == resource.data.buyerId
                    );
      allow delete: if isAdmin()
                    || (isSignedIn() && request.auth.uid == resource.data.buyerId);
    }

    // ── Users ────────────────────────────────────────────────────────
    // SECURITY: full user doc contains KYC PII. Sign-in required to read.
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isSelf(userId)
                    && request.resource.data.role in ['buyer', 'seller'];

      // SECURITY: self-update allowlist. loyaltyPoints REMOVED — backend-only
      // (was a self-mint vector). To redeem, write to pointsLog and let CF
      // settle the balance.
      allow update: if isAdmin()
                    || (isSelf(userId)
                        && changedKeys().hasOnly([
                          'name', 'shopName', 'shopDesc', 'bio',
                          'avatarUrl', 'photoURL',
                          'instapay', 'phone', 'bank', 'accountNum',
                          'accountHolder', 'tin',
                          'twoFactorEnabled',
                          'updatedAt'
                        ]));

      allow delete: if isAdmin();
    }

    // ── Public Profiles (safe-field mirror) ──────────────────────────
    match /publicProfiles/{userId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Settings ─────────────────────────────────────────────────────
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Coupons ──────────────────────────────────────────────────────
    match /coupons/{couponId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // SECURITY: buyers may ONLY +1 usageCount on redemption.
      // Previous rule allowed arbitrary usageCount writes — let attackers
      // reset count to 0 to bypass single-use coupons, or jam to MAX to
      // disable a competitor's promo.
      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && changedKeys().hasOnly(['usageCount'])
                      && request.resource.data.usageCount == resource.data.usageCount + 1
                    );
    }

    // ── Notifications ────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Admin can target anyone. Sellers can only notify themselves (e.g.,
      // local app-driven banners) — order-flow notifications are written by
      // Cloud Functions, which bypass rules. This blocks seller-to-buyer spam.
      allow create: if isAdmin()
                    || (isSeller() && request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
                    && changedKeys().hasOnly(['read']);
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ── Q&A ──────────────────────────────────────────────────────────
    match /qa/{qaId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.askerId == request.auth.uid;
      allow update: if isAdmin()
                    || (isSignedIn()
                        && changedKeys().hasOnly(['answer', 'answeredAt', 'answererId'])
                        && (
                          get(/databases/$(database)/documents/products/$(resource.data.productId)).data.sellerId == request.auth.uid
                          || isAdmin()
                        ));
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.askerId == request.auth.uid);
    }

    // ── Disputes ─────────────────────────────────────────────────────
    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.buyerId == request.auth.uid
                        && changedKeys().hasOnly(['message', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // ── Reports ──────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isSignedIn() && (
        resource.data.reporterId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn()
                    && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Follows ──────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // ── Payouts ──────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      allow read: if isSignedIn() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
      allow create: if isSeller() && isNotBanned()
                    && request.resource.data.sellerId == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Collections ──────────────────────────────────────────────────
    match /collections/{collectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Newsletter Subscribers ───────────────────────────────────────
    match /newsletter/{subId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 254;
      // SECURITY: unsubscribe goes through Cloud Function with signed token —
      // unauthenticated mass-delete (enumerate by email or guess doc IDs)
      // is no longer allowed from client. Users delete their own only.
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow update: if isAdmin();
    }

    // ── Affiliates ───────────────────────────────────────────────────
    match /affiliates/{sellerId} {
      allow read: if true;
      // SECURITY: previous rule (allow write) let the seller self-set
      // commissionRate. Now restricted to a small allowlist; commissionRate
      // is admin-only.
      allow create: if isSignedIn() && request.auth.uid == sellerId;
      allow update: if isAdmin()
                    || (
                      isSignedIn() && request.auth.uid == sellerId
                      && changedKeys().hasOnly(['enabled', 'displayName', 'payoutMethod', 'updatedAt'])
                    );
      allow delete: if isAdmin();
    }

    // ── Loyalty Points Log ───────────────────────────────────────────
    match /users/{userId}/pointsLog/{logId} {
      allow read: if isSelf(userId);
      // SECURITY: Cloud Functions write `earn` entries (admin SDK bypasses rules).
      // Buyers can ONLY create a `redeem` entry with a negative point value,
      // and CF will validate against actual balance before settling.
      // Previous rule allowed any value → self-mint.
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && request.resource.data.type == 'redeem'
                    && request.resource.data.pts is int
                    && request.resource.data.pts < 0;
      allow update, delete: if isAdmin();
    }

    // ── Messages ─────────────────────────────────────────────────────
    match /messages/{threadId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      // SECURITY: existing participant may update metadata (e.g., lastReadAt)
      // but CANNOT alter the participants list (would let them kick the
      // other party or inject a third).
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participants
                    && request.resource.data.participants == resource.data.participants;
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participants;
      allow delete: if isAdmin();

      match /msgs/{msgId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/messages/$(threadId)).data.participants;
        allow create: if isSignedIn() &&
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/messages/$(threadId)).data.participants;
        allow update, delete: if isAdmin();
      }
    }

    // ── KYC Requests ─────────────────────────────────────────────────
    match /kycRequests/{reqId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Abandoned Carts ──────────────────────────────────────────────
    match /abandonedCarts/{userId} {
      allow read, write, delete: if isSelf(userId) || isAdmin();
    }

    // ── Campaigns ────────────────────────────────────────────────────
    match /campaigns/{campId} {
      allow read, write, delete: if isAdmin();
    }

    // ── Email Failures (CF-written, admin-only) ──────────────────────
    // Cloud Function `onOrderStatusChange` + `processEmailCampaigns`
    // write here on Resend 4xx/5xx so an admin can re-send manually.
    // Admin SDK bypasses rules; clients are admin-read/delete only.
    match /emailFailures/{failId} {
      allow read, delete: if isAdmin();
      allow create, update: if false;            // CF only (admin SDK)
    }

    // ── Payments audit (Kashier; CF-written, admin/owner read) ───────
    // createKashierPayment + kashierWebhook (admin SDK) write one doc per
    // order keyed by orderId. Clients NEVER write here (no self-recording a
    // payment). Buyer may read their own row; admin reads all.
    match /payments/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.buyerId == request.auth.uid);
      allow create, update, delete: if false;    // CF only (admin SDK)
    }

    // ── Download audit log (CF-written, admin-only) ──────────────────
    // Every successful download via the proxy is logged. Admin can
    // review for fraud / chargeback evidence.
    match /downloadLog/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;    // CF only
    }

    // ── Upload violations (CF-written, admin-only) ───────────────────
    // Files that failed MIME magic-byte verification and were auto-deleted.
    match /uploadViolations/{violationId} {
      allow read, delete: if isAdmin();
      allow create, update: if false;            // CF only
    }

    // ── Public Purchases (opt-in social-proof ticker) ────────────────
    // CF writes a first-name-only + product-name entry here when a buyer
    // ticked the public-attribution checkbox at checkout. The homepage
    // ticker reads this collection. Never contains UID/email/last name.
    match /publicPurchases/{purchaseId} {
      allow read: if true;
      allow create, update, delete: if false;    // CF only
    }

    // ── Google Drive per-buyer grants (CF-written, admin-only) ───────
    // downloadFile creates one of these each time a buyer downloads a
    // Drive-hosted product; revokeExpiredDriveGrants flips revokedAt
    // after 30 days. Holds the buyer's email so we can re-grant if
    // they hit Download again before expiry — keep admin-only read.
    match /driveGrants/{grantId} {
      allow read, delete: if isAdmin();
      allow create, update: if false;            // CF only
    }

    // ── Product status audit (forensic log) ──────────────────────────
    // Written by the onProductStatusAudit Cloud Function every time a
    // product's status changes. Admin-readable so we can investigate
    // mysterious flips like the 2026-05-24 incident. Never client-writable.
    match /productStatusAudit/{entryId} {
      allow read: if isAdmin();
      allow write: if false;                   // CF only
    }

    // ── Presence ─────────────────────────────────────────────────────
    match /presence/{presId} {
      allow read: if true;
      // SECURITY: anonymous presence is fine for live counts, but writes are
      // now tied to the doc-ID = uid pattern so users can only manage their
      // own. Previous `allow update, delete: if true` was a DoS vector
      // (anyone could wipe everyone's presence).
      allow create: if request.resource.data.expiresAt is number
                    && (
                      // Signed-in: doc ID must match their uid
                      (isSignedIn() && presId == request.auth.uid)
                      // Unauthenticated: must include their own session token as doc ID
                      || (!isSignedIn() && presId.matches('guest_.*'))
                    );
      allow update, delete: if (isSignedIn() && presId == request.auth.uid)
                            || isAdmin();
    }

  }
}
