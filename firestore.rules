rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isSeller() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isNotBanned() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('disabled', false) == false;
    }

    // ── Products ─────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if resource.data.status == 'approved'
                  || isAdmin()
                  || (isSignedIn() && request.auth.uid == resource.data.sellerId);

      // Only verified sellers (not banned) can create; status must be pending or draft
      allow create: if isSeller() && isNotBanned()
                    && request.resource.data.sellerId == request.auth.uid
                    && request.resource.data.status in ['pending', 'draft'];

      allow update: if isAdmin()
                    || (isSeller() && isNotBanned() && request.auth.uid == resource.data.sellerId);

      allow delete: if isAdmin()
                    || (isSeller() && request.auth.uid == resource.data.sellerId);
    }

    // ── Orders ───────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.buyerId ||
        resource.data.sellerIds.hasAny([request.auth.uid]) ||
        isAdmin()
      );

      // Only authenticated, non-banned buyers can create orders
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.status == 'pending';

      // Admin or involved seller can update; buyer cannot change their own order
      allow update: if isAdmin()
                    || (isSeller() && resource.data.sellerIds.hasAny([request.auth.uid]));

      allow delete: if isAdmin();
    }

    // ── Reviews ──────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      // Only verified buyers can create reviews
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if isAdmin()
                            || (isSignedIn() && request.auth.uid == resource.data.buyerId);
    }

    // ── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      // PUBLIC READ — required so unauthenticated visitors can view seller storefronts,
      // see product author info, etc. Marketplace UX needs this. Payment info (Instapay,
      // phone) is visible by design so buyers can pay sellers directly.
      // Sensitive data (KYC docs, 2FA secrets, OTP codes) should NEVER be stored on this
      // doc — use the kycRequests collection (admin-only) for KYC.
      allow read: if true;

      allow create: if isSelf(userId)
                    && request.resource.data.role in ['buyer', 'seller'];

      // Users can update their own doc but CANNOT change role, disabled, or KYC fields
      // (KYC fields are mirrored from kycRequests via the onKYCApproval Cloud Function)
      allow update: if isAdmin()
                    || (isSelf(userId)
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['role', 'disabled', 'kycStatus', 'kycRejectReason',
                                     'kycReviewedAt', 'totalSales', 'tier']));

      allow delete: if isAdmin();
    }

    // ── Settings ─────────────────────────────────────────────────────
    match /settings/{doc} {
      allow read: if true;   // payment info needed for checkout (unauthenticated preview)
      allow write: if isAdmin();
    }

    // ── Coupons ──────────────────────────────────────────────────────
    match /coupons/{couponId} {
      allow read: if true;   // needed for coupon validation at checkout
      allow create, delete: if isAdmin();
      // Allow increment of usageCount on redemption (buyers trigger this)
      allow update: if isAdmin()
                    || (isSignedIn()
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['usageCount']));
    }

    // ── Notifications ────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Admin and sellers can create notifications for buyers
      allow create: if isAdmin() || isSeller();
      // Users can mark their own as read (update only 'read' field)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      // Users can delete their own; admins can delete any
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ── Q&A ──────────────────────────────────────────────────────────
    match /qa/{qaId} {
      // Anyone can read Q&A (shown on product pages)
      allow read: if true;
      // Any signed-in, non-banned user can post a question
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.askerId == request.auth.uid;
      // Only the product's seller or an admin can add/update an answer
      allow update: if isAdmin()
                    || (isSignedIn()
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['answer', 'answeredAt', 'answererId'])
                        && (
                          // Seller who owns the product
                          get(/databases/$(database)/documents/products/$(resource.data.productId)).data.sellerId == request.auth.uid
                          || isAdmin()
                        ));
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.askerId == request.auth.uid);
    }

    // ── Disputes / Refund Requests ────────────────────────────────────
    match /disputes/{disputeId} {
      // Buyer who opened it, involved seller, or admin can read
      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      // Only the buyer can open a dispute, and only for their own orders
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.buyerId == request.auth.uid;
      // Admin resolves; involved parties cannot self-modify status
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.buyerId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['message', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // ── Reports ──────────────────────────────────────────────────────
    match /reports/{reportId} {
      // Only the reporter and admins can read
      allow read: if isSignedIn() && (
        resource.data.reporterId == request.auth.uid || isAdmin()
      );
      // Any signed-in user can submit a report
      allow create: if isSignedIn()
                    && request.resource.data.reporterId == request.auth.uid;
      // Only admin can update (change status) or delete
      allow update, delete: if isAdmin();
    }

    // ── Follows ───────────────────────────────────────────────────────
    // Doc IDs are "{followerId}_{sellerId}" for O(1) existence checks
    match /follows/{followId} {
      allow read: if true;   // used for public follower counts
      // Only the follower can create/delete their own follow
      allow create: if isSignedIn()
                    && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.followerId == request.auth.uid;
      allow update: if false;  // follows are immutable; delete + recreate instead
    }

    // ── Payouts ───────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      // Seller can read their own; admin can read all
      allow read: if isSignedIn() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
      // Only sellers can request payouts for themselves
      allow create: if isSeller() && isNotBanned()
                    && request.resource.data.sellerId == request.auth.uid
                    && request.resource.data.status == 'pending';
      // Only admin can update payout status
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Collections (admin-curated product bundles) ───────────────────
    match /collections/{collectionId} {
      allow read: if true;     // shown on public marketplace homepage
      allow create, update, delete: if isAdmin();
    }

    // ── Newsletter Subscribers ────────────────────────────────────────
    match /newsletter/{subId} {
      // Only admin can list/read all subscribers
      allow read: if isAdmin();
      // Anyone (incl. unauthenticated) can subscribe with a valid email
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 254;
      // Allow unsubscribe by anyone who knows the doc ID (linked from email)
      allow delete: if true;
      allow update: if isAdmin();
    }

    // ── Affiliates ────────────────────────────────────────────────────
    // Each seller has a doc identified by their uid.
    match /affiliates/{sellerId} {
      // Anyone can read (for click tracking from unauthenticated visitors)
      allow read: if true;
      // Only the owning seller can write their settings (commission rate)
      allow write: if isSignedIn() && request.auth.uid == sellerId;
      // Admin can update/delete
      allow update, delete: if isAdmin();
    }

    // ── Loyalty Points Log (subcollection of users) ───────────────────
    match /users/{userId}/pointsLog/{logId} {
      // Users can only read their own log
      allow read: if isSelf(userId);
      // Backend (via Cloud Functions or client after purchase) writes points
      allow create: if isSignedIn()
                    && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    // ── Messages (Buyer ↔ Seller direct chat) ─────────────────────────
    match /messages/{threadId} {
      allow read, write: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants;

      match /msgs/{msgId} {
        // Can read if signed-in and the parent thread lists you as participant
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/messages/$(threadId)).data.participants;
        // Can create if you are a participant and the senderId matches yourself
        allow create: if isSignedIn() &&
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/messages/$(threadId)).data.participants;
        allow update, delete: if isAdmin();
      }
    }

    // ── KYC Requests (admin review queue) ─────────────────────────────
    match /kycRequests/{reqId} {
      // Reading limited to admin or the submitting user
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Abandoned Carts (for recovery emails) ─────────────────────────
    match /abandonedCarts/{userId} {
      allow read, write, delete: if isSelf(userId) || isAdmin();
    }

    // ── Email Campaigns (admin only) ──────────────────────────────────
    match /campaigns/{campId} {
      allow read, write, delete: if isAdmin();
    }

    // ── Real-time presence (who's viewing what) ───────────────────────
    match /presence/{presId} {
      // Anyone can read (live count)
      allow read: if true;
      // Anyone can create their own presence doc
      allow create: if request.resource.data.expiresAt is number;
      // Update / delete only by creator (we store userId but allow guests too)
      allow update, delete: if true; // self-managed via heartbeat; safe because docs are tiny & TTL-cleaned
    }

  }
}
