rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isSeller() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isNotBanned() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('disabled', false) == false;
    }

    // ── Products ─────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if resource.data.status == 'approved'
                  || isAdmin()
                  || (isSignedIn() && request.auth.uid == resource.data.sellerId);

      // Only verified sellers (not banned) can create; status must be pending or draft
      allow create: if isSeller() && isNotBanned()
                    && request.resource.data.sellerId == request.auth.uid
                    && request.resource.data.status in ['pending', 'draft'];

      allow update: if isAdmin()
                    || (isSeller() && isNotBanned() && request.auth.uid == resource.data.sellerId);

      allow delete: if isAdmin()
                    || (isSeller() && request.auth.uid == resource.data.sellerId);
    }

    // ── Orders ───────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.buyerId ||
        resource.data.sellerIds.hasAny([request.auth.uid]) ||
        isAdmin()
      );

      // Only authenticated, non-banned buyers can create orders
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.status == 'pending';

      // Admin or involved seller can update; buyer cannot change their own order
      allow update: if isAdmin()
                    || (isSeller() && resource.data.sellerIds.hasAny([request.auth.uid]));

      allow delete: if isAdmin();
    }

    // ── Reviews ──────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      // Only verified buyers can create reviews
      allow create: if isSignedIn() && isNotBanned()
                    && request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if isAdmin()
                            || (isSignedIn() && request.auth.uid == resource.data.buyerId);
    }

    // ── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read (needed for seller payment info in checkout)
      allow read: if isSignedIn();

      allow create: if isSelf(userId)
                    && request.resource.data.role in ['buyer', 'seller'];

      // Users can update their own doc but CANNOT change role or disabled status
      allow update: if isAdmin()
                    || (isSelf(userId)
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['role', 'disabled']));

      allow delete: if isAdmin();
    }

    // ── Settings ─────────────────────────────────────────────────────
    match /settings/{doc} {
      allow read: if true;   // payment info needed for checkout (unauthenticated preview)
      allow write: if isAdmin();
    }

    // ── Coupons ──────────────────────────────────────────────────────
    match /coupons/{couponId} {
      allow read: if true;   // needed for coupon validation at checkout
      allow create, delete: if isAdmin();
      // Allow increment of usageCount on redemption (buyers trigger this)
      allow update: if isAdmin()
                    || (isSignedIn()
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['usageCount']));
    }

    // ── Notifications ────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Admin and sellers can create notifications for buyers
      allow create: if isAdmin() || isSeller();
      // Users can mark their own as read (update only 'read' field)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      // Users can delete their own; admins can delete any
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

  }
}
