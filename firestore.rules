rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Products ─────────────────────────────────────────────────────
    match /products/{productId} {
      // Anyone can read approved products; sellers see their own; admins see all
      allow read: if resource.data.status == 'approved'
                  || isAdmin()
                  || (isSignedIn() && request.auth.uid == resource.data.sellerId);

      // Any signed-in user can create (role checked in app logic)
      allow create: if isSignedIn();

      // Seller can update their own product; admin can update any
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid == resource.data.sellerId);

      // Seller can delete their own product; admin can delete any
      allow delete: if isAdmin()
                    || (isSignedIn() && request.auth.uid == resource.data.sellerId);
    }

    // ── Orders ───────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Buyer, any involved seller, or admin can read
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.buyerId ||
        resource.data.sellerIds.hasAny([request.auth.uid]) ||
        isAdmin()
      );

      // Any signed-in user can create an order
      allow create: if isSignedIn();

      // Only admin or an involved seller can update (approve/reject)
      allow update: if isAdmin()
                    || (isSignedIn() && resource.data.sellerIds.hasAny([request.auth.uid]));

      allow delete: if isAdmin();
    }

    // ── Reviews ──────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin()
                            || (isSignedIn() && request.auth.uid == resource.data.buyerId);
    }

    // ── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own doc; sellers/buyers are readable by signed-in users
      // for payment info display in checkout
      allow read: if isSignedIn();

      // Only the user themselves can create their own doc (on registration)
      allow create: if isSelf(userId);

      // Users can update their own doc BUT cannot change their own role
      // Admins can update anything (including role changes)
      allow update: if isAdmin()
                    || (isSelf(userId) && !('role' in request.resource.data));

      allow delete: if isAdmin();
    }

    // ── Settings ─────────────────────────────────────────────────────
    match /settings/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
