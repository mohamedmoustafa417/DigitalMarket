rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Payment proof images ──────────────────────────────────────────
    // Only the uploading buyer can write their own proof;
    // any signed-in user (admin / seller) can read to review it.
    match /proofs/{userId}/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024   // max 2 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Product files (seller uploads) ───────────────────────────────
    // Each seller can upload files only under their own UID folder.
    // Buyers / admin can read (download) once the order is approved — the
    // actual download URL is stored in Firestore and served directly from
    // Storage; Firebase Storage security rules don't restrict public
    // download URLs, but we still lock write access here.
    match /products/{sellerId}/{filename} {
      // Any authenticated user may read (download link already requires auth via the app)
      allow read:  if request.auth != null;

      // Only the owning seller (or admin) may write; enforce size + type limits
      allow write: if request.auth != null
                   && request.auth.uid == sellerId
                   && request.resource.size < 200 * 1024 * 1024  // max 200 MB
                   && (
                     // Digital product types
                     request.resource.contentType.matches('application/.*') ||
                     request.resource.contentType.matches('image/.*')       ||
                     request.resource.contentType.matches('video/.*')       ||
                     request.resource.contentType.matches('audio/.*')       ||
                     request.resource.contentType.matches('text/.*')        ||
                     request.resource.contentType == 'font/ttf'             ||
                     request.resource.contentType == 'font/otf'             ||
                     request.resource.contentType == 'font/woff'            ||
                     request.resource.contentType == 'font/woff2'
                   );

      // Only the seller who uploaded can delete their own files
      allow delete: if request.auth != null && request.auth.uid == sellerId;
    }

    // ── Default deny everything else ─────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
