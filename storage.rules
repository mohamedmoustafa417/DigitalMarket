rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──────────────────────────────────────────────────────
    // SVG is the one image/* subtype we never accept: <svg><script> runs
    // when navigated to directly (even if rendered inside <img> tags is safe,
    // sellers can hand out the raw URL). Block at upload.
    function isSafeImage() {
      return request.resource.contentType.matches('image/.*')
             && !request.resource.contentType.matches('image/svg.*');
    }

    // ── Payment proof images ──────────────────────────────────────────
    // SECURITY: reads tightened — proofs often contain real names + bank
    // reference numbers + phone numbers. Previous rule (allow read: if
    // signed-in) leaked every buyer's proof to every other signed-in user.
    // Now only the uploading buyer + admins can read; sellers see proofs
    // via the admin-review flow.
    match /proofs/{userId}/{filename} {
      allow read:  if request.auth != null
                   && (request.auth.uid == userId
                       || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && isSafeImage();
    }

    // ── Product files (seller uploads) ───────────────────────────────
    match /products/{sellerId}/{filename} {
      // Reads still open to any authenticated user (buyers download after
      // approval). Note: the real access-gate for downloads should move to
      // a Cloud Function proxy that validates `downloadExpired` per request;
      // tracked separately (the existing `downloadUrl` token never expires,
      // which is a known architectural risk).
      allow read:  if request.auth != null;

      // SECURITY: file types unchanged EXCEPT SVG now blocked (XSS risk
      // when seller hosts an SVG with embedded <script>).
      allow write: if request.auth != null
                   && request.auth.uid == sellerId
                   && request.resource.size < 200 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('application/.*') ||
                     isSafeImage()                                            ||
                     request.resource.contentType.matches('video/.*')        ||
                     request.resource.contentType.matches('audio/.*')        ||
                     request.resource.contentType.matches('text/.*')         ||
                     request.resource.contentType == 'font/ttf'              ||
                     request.resource.contentType == 'font/otf'              ||
                     request.resource.contentType == 'font/woff'             ||
                     request.resource.contentType == 'font/woff2'
                   );

      allow delete: if request.auth != null && request.auth.uid == sellerId;
    }

    // ── KYC documents (sensitive — admin-read needed for review) ─────
    // SECURITY: admin read added so the admin KYC review queue actually
    // works without relying on long-lived getDownloadURL tokens captured
    // in Firestore (which would never expire even if KYC is later denied).
    match /kyc/{userId}/{filename} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && isSafeImage();
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Default deny everything else ─────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
